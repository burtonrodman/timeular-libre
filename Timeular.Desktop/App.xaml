<Application x:Class="Timeular.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Timeular.Desktop"
             xmlns:tb="clr-namespace:Hardcodet.Wpf.TaskbarNotification;assembly=Hardcodet.Wpf.TaskbarNotification">
    <Application.Resources>
        <!-- declare notify icon in XAML to ensure it is properly initialized -->
        <tb:TaskbarIcon x:Key="TrayIcon"
                        Visibility="Visible"
                        IconSource="/Resources/AppIcon.ico"
                        ToolTipText="Timeular Desktop" />
    </Application.Resources>
</Application>
