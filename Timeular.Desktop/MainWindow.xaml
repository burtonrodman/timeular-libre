<Window x:Class="Timeular.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Timeular.Desktop"
        mc:Ignorable="d"
        Title="Event Entry" Height="300" Width="400">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Event Type:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="EventTypeText" Grid.Row="0" Grid.Column="1" Margin="4"/>

        <TextBlock Text="Description:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="DescriptionText" Grid.Row="1" Grid.Column="1" Margin="4"/>

        <TextBlock Text="Additional Data:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Top"/>
        <TextBox x:Name="AdditionalDataText" Grid.Row="2" Grid.Column="1" Margin="4" AcceptsReturn="True"/>

        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="SubmitButton" Content="Submit" Width="80" Margin="4" Click="SubmitButton_Click"/>
            <Button Content="Cancel" Width="80" Margin="4" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
