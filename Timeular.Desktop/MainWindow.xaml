<Window x:Class="Timeular.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Timeular"
        ResizeMode="CanResizeWithGrip"
        Background="#1E1E1E"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- suppress default blue selection highlight on list items -->
        <Style TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- ── Input + settings docked to bottom ── -->
        <Border DockPanel.Dock="Bottom" Background="#252526" Padding="10,8">
            <StackPanel>

                <!-- Side-name prompt (visible only for unconfigured sides) -->
                <Grid x:Name="SideNameRow" Visibility="Collapsed" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SideNameInput" Grid.Column="0"
                             Background="#1E1E1E" Foreground="#D4D4D4"
                             BorderBrush="#3C3C3C" CaretBrush="#D4D4D4"
                             Padding="8,6" FontSize="13"
                             KeyDown="SideNameInput_KeyDown"
                             ToolTip="Give this side a name, then press Enter"/>
                    <TextBlock Grid.Column="1" Text="Name this side"
                               Foreground="#858585" FontSize="11"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </Grid>

                <!-- Description input row -->
                <Grid x:Name="DescriptionRow">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="DescriptionInput" Grid.Column="0"
                             Background="#1E1E1E" Foreground="#D4D4D4"
                             BorderBrush="#3C3C3C" CaretBrush="#D4D4D4"
                             Padding="8,6" FontSize="13"
                             KeyDown="DescriptionInput_KeyDown"
                             ToolTip="Type a description and press Enter to log"/>
                    <Button Grid.Column="1" Content="✕" Width="32" Height="32"
                            Margin="6,0,0,0"
                            Background="#333333" Foreground="#858585"
                            BorderThickness="0" FontSize="14"
                            Click="CancelButton_Click"
                            ToolTip="Hide (Esc)"/>
                </Grid>

                <!-- Auto-close setting -->
                <CheckBox x:Name="AutoCloseCheckbox"
                          Margin="2,8,0,0"
                          Content="Close window after logging"
                          Foreground="#858585" FontSize="11"
                          Checked="AutoCloseCheckbox_Changed"
                          Unchecked="AutoCloseCheckbox_Changed"/>
            </StackPanel>
        </Border>

        <!-- ── Flip history list — bottom-anchored ── -->
        <ScrollViewer x:Name="HistoryScroller"
                      Background="#1E1E1E"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- spacer pushes items to bottom -->
                <Border Grid.Row="0"/>
                <ListBox x:Name="HistoryList" Grid.Row="1"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="False"
                         Focusable="False">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8" BorderThickness="0,0,0,1"
                                    BorderBrush="#2D2D2D">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Status icon -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding StatusIcon}"
                                               Foreground="{Binding StatusBrush}"
                                               FontSize="13" VerticalAlignment="Top"
                                               Margin="0,2,10,0"/>

                                    <!-- Content -->
                                    <StackPanel Grid.Column="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding TimeText}"
                                                       Foreground="#858585" FontSize="11"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Label}"
                                                       Foreground="#D4D4D4" FontSize="13"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}"
                                                   Foreground="#9CDCFE" FontSize="12"
                                                   Margin="0,3,0,0" TextWrapping="Wrap"
                                                   Visibility="{Binding HasDescription, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </ScrollViewer>

    </DockPanel>
</Window>
