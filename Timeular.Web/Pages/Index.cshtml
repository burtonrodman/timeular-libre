@page
@model IndexModel
@using Microsoft.AspNetCore.Mvc.RazorPages
@{
    ViewData["Title"] = "Action";
    var action = Request.Query["action"].ToString();
}

<div class="text-center">
    <h1 class="display-4">Action received</h1>
    @if (!string.IsNullOrEmpty(action))
    {
        <p>You flipped: <strong>@action</strong></p>
        <form method="post" asp-page-handler="Record">
            <input type="hidden" name="action" value="@action" />
            <button class="btn btn-primary">Record action</button>
        </form>
        <a class="btn btn-secondary" asp-page="/DevOps" asp-route-action="@action">Log to DevOps...</a>
    }
    else
    {
        <p>No action parameter supplied.</p>
    }
</div>
